{
    "name": "cpse-devcontainer",
    "image": "mcr.microsoft.com/devcontainers/python:3.12",
    "features": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "ghcr.io/va-h/devcontainers-features/uv:1": {
            "version": "latest"
        },
        "ghcr.io/guiyomh/features/just:0": {}
    },
    "mounts": [
        "source=${localEnv:HOME}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
        "source=cpse-venv,target=${containerWorkspaceFolder}/.venv,type=volume"
    ],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.debugpy",
                "Anthropic.claude-code"
            ],
            "settings": {
                "python.defaultInterpreterPath": "${containerWorkspaceFolder}/.venv/bin/python",
                "python.testing.pytestEnabled": true,
                "python.testing.pytestArgs": ["tests"],
                "python.testing.unittestEnabled": false,
                "claude.terminalCommand.executionPolicy": "always"
            }
        }
    },
    "containerEnv": {
        "PYTHONPATH": "${containerWorkspaceFolder}",
        "CLAUDE_CONFIG_DIR": "/home/vscode/.claude",
        "DISABLE_AUTOUPDATER": "1",
        "CLAUDE_ACCEPT_DEFAULTS": "true"
    },
    "postCreateCommand": "sudo chown vscode:vscode .venv && just install && printf '[engine cpse]\\nmodule_name: cpse\\nclass_name: CPSE\\n\\n[engine cpse-timepoints]\\nmodule_name: cpse\\nclass_name: CPSETimepoints\\n' > ~/.up.ini && npm install -g @anthropic-ai/claude-code",
    "remoteUser": "vscode"
}
